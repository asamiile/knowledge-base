# API base URL（ブラウザが叩く公開 URL。本番では https://api.example.com など実ホストに合わせる）
NEXT_PUBLIC_API_URL=http://localhost:8001

# Cloud Run の *.run.app からの 301 リダイレクト先（https:// のカスタムドメイン、末尾スラッシュ不要）。未設定ならリダイレクトしない。
# NEXT_PUBLIC_CANONICAL_SITE_URL=https://app.example.com

# バックエンドの AUTH_ENABLED=true とせて有効化。未設定・false のときログイン画面はスキップされます。
# NEXT_PUBLIC_AUTH_ENABLED=true
